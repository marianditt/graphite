kinds:
  requirement: { key: REQ }
  adr: { key: ADR }
  service: { key: SVC }
  test: { key: TST }
  compliance: { key: CPL }
  runbook: { key: RBK }
  infra: { key: INF }
edges:
  implemented_by: { from: requirement, to: service }
  verified_by: { from: requirement, to: test }
  describes: { from: adr, to: service }
  references: { from: any, to: any }
  relates_to: { from: any, to: any }
  evidence: { from: any, to: evidence }
